<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="BottomNavTextAppearance" parent="TextAppearance.AppCompat.Caption">
        <item name="fontFamily">@font/ibm_plex_sans_semi_bold</item>
        <item name="android:textSize">10sp</item>
    </style>

    <style name="ToolbarTitleAppearance" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="fontFamily">@font/ibm_plex_sans_bold</item>
        <item name="android:textColor">@color/colorText</item>
    </style>

    <style name="MyToolbarStyle" parent="Widget.AppCompat.Toolbar">
        <item name="titleTextAppearance">@style/ToolbarTitleAppearance</item>
        <item name="android:background">@color/colorSecondary</item>
    </style>

    <style name="CustomTabText" parent="TextAppearance.Design.Tab">
        <item name="fontFamily">@font/ibm_plex_sans_semi_bold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">true</item>
    </style>
</resources>