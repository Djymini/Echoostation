<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.mediaFragments.AlbumFragment">
    <GridLayout
        android:id="@+id/button_container"
        android:layout_marginVertical="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:paddingHorizontal="8dp">
        <LinearLayout
            android:id="@+id/recently_item"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:layout_marginBottom="24dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp">
                <ImageView
                    android:layout_width="104dp"
                    android:layout_height="104dp"
                    android:layout_weight="1"
                    android:adjustViewBounds="true"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/album_cover"
                    android:src="@drawable/echoostation_cover_recently_3x"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:fontFamily="@font/ibm_plex_sans_bold"
                android:includeFontPadding="false"
                android:text="@string/recently_listening"
                android:textColor="@color/colorText"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/recently_counter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:fontFamily="@font/ibm_plex_sans_regular"
                android:includeFontPadding="false"
                android:text="0 morceaux"
                android:textSize="11sp"
                android:textColor="@color/colorText"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/favorite_item"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:layout_marginBottom="24dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp">
                <ImageView
                    android:layout_width="104dp"
                    android:layout_height="104dp"
                    android:layout_weight="1"
                    android:adjustViewBounds="true"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/album_cover"
                    android:src="@drawable/echoostation_cover_favorite_3x"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:fontFamily="@font/ibm_plex_sans_bold"
                android:includeFontPadding="false"
                android:text="@string/favoris"
                android:textColor="@color/colorText"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/favorite_counter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:fontFamily="@font/ibm_plex_sans_regular"
                android:includeFontPadding="false"
                android:text="0 morceaux"
                android:textSize="11sp"
                android:textColor="@color/colorText"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/most_listening_item"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:layout_marginBottom="24dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <androidx.cardview.widget.CardView
                android:layout_width="104dp"
                android:layout_height="104dp"
                app:cardCornerRadius="8dp">
                <RelativeLayout
                    android:id="@+id/playlist_illustration_trend"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/echoostation_cover_trend_3x"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentEnd="true"
                        android:layout_margin="2dp"
                        android:fontFamily="@font/ibm_plex_sans_bold"
                        android:text="LES PLUS ECOUTEES"
                        android:textSize="8dp"
                        android:textColor="#778EA2"/>
                    <androidx.cardview.widget.CardView
                        android:id="@+id/album_image_third_container"
                        android:layout_alignParentEnd="true"
                        android:layout_centerInParent="true"
                        android:layout_marginEnd="6dp"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        app:cardCornerRadius="100dp">
                        <ImageView
                            android:id="@+id/album_image_third"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/echoostation_placeholder_album_3x"/>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/album_image_second_container"
                        android:layout_alignParentStart="true"
                        android:layout_centerInParent="true"
                        android:layout_marginStart="6dp"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        app:cardCornerRadius="100dp">
                        <ImageView
                            android:id="@+id/album_image_second"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/echoostation_placeholder_album_3x"/>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/album_image_first_container"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        app:cardCornerRadius="100dp"
                        android:layout_centerInParent="true"
                        app:cardBackgroundColor="#243B53">
                        <androidx.cardview.widget.CardView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_gravity="center"
                            app:cardCornerRadius="100dp">
                            <ImageView
                                android:id="@+id/album_image_first"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/echoostation_placeholder_album_3x"/>
                        </androidx.cardview.widget.CardView>
                    </androidx.cardview.widget.CardView>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:fontFamily="@font/ibm_plex_sans_bold"
                android:includeFontPadding="false"
                android:text="@string/most_listening"
                android:textColor="@color/colorText"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tracks_counter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:fontFamily="@font/ibm_plex_sans_regular"
                android:includeFontPadding="false"
                android:text="0 morceaux"
                android:textSize="11sp"
                android:textColor="@color/colorText"/>
        </LinearLayout>

    </GridLayout>

    <com.l4digital.fastscroll.FastScrollRecyclerView
        android:id="@+id/recycler_view_media"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/button_container"
        android:clipToPadding="false"
        android:paddingBottom="82dp"/>

    <ImageButton
        android:id="@+id/add_button"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="92dp"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:src="@drawable/round_add_circle_outline_24"
        android:scaleType="fitCenter"
        app:tint="@color/colorText"
        android:background="@color/colorThird"/>

</RelativeLayout>