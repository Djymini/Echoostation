<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".fragments.AlbumInfoFragment">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/background_image"
                android:layout_width="match_parent"
                android:layout_height="410dp"
                android:alpha="0.4"
                android:src="@drawable/echoostation_placeholder_album_3x"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="410dp"
                android:background="@drawable/background_album"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/playlist_image_container"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="40dp"
                app:cardCornerRadius="12dp">
                <ImageView
                    android:id="@+id/album_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/echoostation_placeholder_album_3x"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/playlist_name"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="10dp"
                android:layout_below="@id/playlist_image_container"
                android:fontFamily="@font/ibm_plex_sans_bold"
                android:text="Album"
                android:textAlignment="center"
                android:textSize="20dp"/>

            <TextView
                android:id="@+id/album_date"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="2dp"
                android:layout_below="@id/playlist_name"
                android:fontFamily="@font/ibm_plex_sans_medium"
                android:text="2018"
                android:textAlignment="center"
                android:textSize="16dp"/>

            <LinearLayout
                android:id="@+id/info_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/album_date"
                android:layout_centerHorizontal="true"
                android:gravity="center">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginEnd="12dp">
                    <androidx.cardview.widget.CardView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        app:cardCornerRadius="100dp">
                        <ImageView
                            android:id="@+id/artist_image"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/echoostation_placeholder_album_3x"/>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/artist_name"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="4dp"
                        android:text="Artiste"
                        android:textSize="16dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/number_tracks"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="99 morceaux"
                        android:textSize="16dp"/>

                    <TextView
                        android:id="@+id/duration_total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Durée : 99:99"
                        android:textSize="16dp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/button_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/info_container"
                android:layout_marginTop="20dp"
                android:layout_centerHorizontal="true"
                android:gravity="center">
                <Button
                    android:id="@+id/play_button"
                    android:layout_width="150dp"
                    android:layout_height="60dp"
                    android:layout_marginEnd="10dp"
                    android:backgroundTint="@color/accentColor"
                    android:text="Jouer"
                    android:textSize="16dp"
                    android:textColor="@color/colorText"
                    android:drawableLeft="@drawable/round_play_arrow_24"
                    android:drawableTint="@color/colorText"/>

                <Button
                    android:id="@+id/shuffle_button"
                    android:layout_width="150dp"
                    android:layout_height="60dp"
                    android:layout_marginStart="10dp"
                    android:backgroundTint="@color/disableText"
                    android:text="Aléatoire"
                    android:textSize="16dp"
                    android:textColor="@color/colorText"
                    android:drawableLeft="@drawable/round_shuffle_24"
                    android:drawableTint="@color/colorText"/>
            </LinearLayout>
        </RelativeLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view_song_album"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:paddingBottom="82dp"
            android:nestedScrollingEnabled="false"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>