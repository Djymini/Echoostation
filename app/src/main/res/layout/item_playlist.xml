<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingHorizontal="8dp"
    android:layout_marginBottom="24dp"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">
    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="8dp">
        <ImageView
            android:id="@+id/playlist_cover"
            android:layout_width="104dp"
            android:layout_height="104dp"
            android:layout_weight="1"
            android:adjustViewBounds="true"
            android:scaleType="centerCrop"
            android:contentDescription="@string/album_cover"
            android:src="@drawable/echoostation_placeholder_playlist_3x"/>

        <GridLayout
            android:id="@+id/playlist_cover2"
            android:layout_width="104dp"
            android:layout_height="104dp"
            android:columnCount="2"
            android:rowCount="2">
            <ImageView
                android:id="@+id/playlist_cover2_image1"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:contentDescription="@string/album_cover"
                android:src="@drawable/echoostation_placeholder_playlist_3x"/>
            <ImageView
                android:id="@+id/playlist_cover2_image2"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:contentDescription="@string/album_cover"
                android:src="@drawable/echoostation_placeholder_playlist_3x"/>
            <ImageView
                android:id="@+id/playlist_cover2_image3"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:contentDescription="@string/album_cover"
                android:src="@drawable/echoostation_placeholder_playlist_3x"/>
            <ImageView
                android:id="@+id/playlist_cover2_image4"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:contentDescription="@string/album_cover"
                android:src="@drawable/echoostation_placeholder_playlist_3x"/>
        </GridLayout>

        <ImageButton
            android:id="@+id/item_menu_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginStart="80dp"
            android:background="@null"
            android:src="@drawable/ic_item__menu"
            app:tint="@color/colorPrimary"/>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/playlist_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:singleLine="true"
        android:fontFamily="@font/ibm_plex_sans_bold"
        android:includeFontPadding="false"
        android:text="Nom de la playlist"
        android:textColor="@color/colorText"
        android:textSize="14sp"/>

    <TextView
        android:id="@+id/tracks_counter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:singleLine="true"
        android:fontFamily="@font/ibm_plex_sans_regular"
        android:includeFontPadding="false"
        android:text="0 morceaux"
        android:textSize="11sp"
        android:textColor="@color/colorText"/>
</LinearLayout>