<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingLeft="10dp"
    android:paddingVertical="10dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.cardview.widget.CardView
        android:id="@+id/music_cover"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="14dp"
        app:cardCornerRadius="4dp">
        <ImageView
            android:id="@+id/image_cover"
            android:layout_width="50dp"
            android:layout_height="50dp"/>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/music_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_toEndOf="@id/music_cover"
        android:layout_toStartOf="@id/music_duration"
        android:fontFamily="@font/m_plus_rounded_1c_bold"
        android:paddingTop="3dp"
        android:text="Titre" />

    <TextView
        android:id="@+id/music_artist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_toEndOf="@id/music_cover"
        android:layout_alignBottom="@id/music_cover"
        android:layout_toStartOf="@id/music_duration"
        android:paddingBottom="3dp"
        android:fontFamily="@font/m_plus_rounded_1c"
        android:text="Artiste"/>

    <TextView
        android:id="@+id/music_duration"
        android:layout_width="45dp"
        android:layout_height="50dp"
        android:gravity="center"
        android:layout_toStartOf="@id/item_menu_button"
        android:paddingBottom="3dp"
        android:fontFamily="@font/m_plus_rounded_1c"
        android:text="99:99"
        android:textSize="12sp"/>

    <ImageButton
        android:id="@+id/item_menu_button"
        android:layout_width="40dp"
        android:layout_height="50dp"
        android:layout_alignParentEnd="true"
        android:src="@drawable/ic_item__menu"
        android:background="@color/trueTransparenceColor"/>

</RelativeLayout>