<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">
    <RelativeLayout
        android:id="@+id/authorization_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">
        <TextView
            android:id="@+id/intro_text_1"
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_marginVertical="16dp"
            android:fontFamily="@font/ibm_plex_sans_medium"
            android:text="@string/intro_text_1"
            android:textSize="20sp"
            android:textColor="@color/colorText"
            android:textAlignment="center"
            android:lineSpacingExtra="-10sp"/>
        <TextView
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_below="@id/intro_text_1"
            android:fontFamily="@font/ibm_plex_sans_regular"
            android:text="@string/intro_text_2"
            android:textSize="16sp"
            android:textColor="@color/colorText"
            android:textAlignment="center"
            android:lineSpacingExtra="-5sp"/>

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_above="@id/intro_text_1"
            android:adjustViewBounds="true"
            android:maxWidth="160dp"
            android:maxHeight="160dp"
            android:scaleType="fitCenter"
            android:layout_marginStart="3dp"
            android:src="@drawable/echoostation_icone_foreground_3x"
            android:contentDescription="@string/logo_desciption"/>

        <RelativeLayout
            android:id="@+id/button_container"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:layout_marginVertical="8dp"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true">
            <Button
                android:id="@+id/confirm_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:fontFamily="@font/ibm_plex_sans_bold"
                android:text="@string/confirm_authorization"
                android:backgroundTint="@color/accentColor"/>
            <Button
                android:id="@+id/quit_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/confirm_button"
                android:fontFamily="@font/ibm_plex_sans_bold"
                android:text="@string/quit_app"
                android:textColor="@color/accentColor"
                android:backgroundTint="@color/transparenceColor"/>
        </RelativeLayout>
    </RelativeLayout>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/app_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="visible">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:title="@string/app_name"
                android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
                android:background="@color/colorSecondary"
                android:visibility="visible"/>

            <LinearLayout
                android:id="@+id/scan_progress_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/toolbar"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="gone"
                android:background="@color/colorSecondary">

                <ProgressBar
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    style="?android:attr/progressBarStyleSmall"
                    android:indeterminate="true"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/scan_progress_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/ibm_plex_sans_medium_italic"
                    android:text="@string/scanning_indicator"
                    android:textColor="@color/colorText"
                    android:textSize="18sp"/>
            </LinearLayout>
        </com.google.android.material.appbar.AppBarLayout>

        <FrameLayout
            android:id="@+id/frame_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior"
            android:layout_marginBottom="?attr/actionBarSize"/>

        <androidx.constraintlayout.motion.widget.MotionLayout
            android:id="@+id/player_bottom_sheet"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/colorThird"
            app:layoutDescription="@xml/player_motion_scene"
            app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

            <TextView
                android:id="@+id/player_album"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="350dp"
                android:layout_marginVertical="4dp"
                android:fontFamily="@font/ibm_plex_sans_medium"
                android:includeFontPadding="false"
                android:text="@string/album"
                android:textSize="15sp"
                android:textColor="@color/colorText"
                android:singleLine="true"
                android:ellipsize="end"
                android:visibility="gone" />

            <!-- Image du player (mini et full) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/player_album_cover"
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:cardCornerRadius="8dp">

                <ImageView
                    android:id="@+id/player_cover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/echoostation_placeholder_album_3x" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/player_album_cover2"
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:cardCornerRadius="8dp">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/player_carousel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:clipToPadding="false"
                    android:clipChildren="false"
                    android:overScrollMode="never"/>

            </androidx.cardview.widget.CardView>

            <!-- Titre et artiste -->
            <TextView
                android:id="@+id/player_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/ibm_plex_sans_bold"
                android:includeFontPadding="false"
                android:singleLine="true"
                android:text="Titre"
                android:textSize="16sp"
                android:textColor="@color/colorText"/>

            <TextView
                android:id="@+id/player_artist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/ibm_plex_sans_regular"
                android:includeFontPadding="false"
                android:singleLine="true"
                android:text="@string/artist"
                android:textSize="14sp"
                android:textColor="@color/colorText"/>

            <!-- Boutons de contrôle (toujours visibles) -->
            <ImageButton
                android:id="@+id/btn_repeat"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@null"
                android:contentDescription="@string/ic_repeat"
                android:scaleType="fitCenter"
                android:src="@drawable/round_repeat_24"
                app:tint="@color/colorText"/>

            <ImageButton
                android:id="@+id/btn_prev"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@null"
                android:contentDescription="@string/ic_previous"
                android:scaleType="fitCenter"
                android:src="@drawable/round_skip_previous_24"
                app:tint="@color/colorText"/>

            <ImageButton
                android:id="@+id/btn_play"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@null"
                android:contentDescription="@string/ic_play_pause"
                android:scaleType="fitCenter"
                android:src="@drawable/round_play_arrow_24"
                app:tint="@color/colorText"/>

            <ImageButton
                android:id="@+id/btn_next"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@null"
                android:contentDescription="@string/ic_next"
                android:scaleType="fitCenter"
                android:src="@drawable/round_skip_next_24"
                app:tint="@color/colorText"/>

            <ImageButton
                android:id="@+id/btn_shuffle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@null"
                android:contentDescription="@string/ic_shuffle"
                android:scaleType="fitCenter"
                android:src="@drawable/round_shuffle_24"
                app:tint="@color/colorText"/>

            <!-- Contenu supplémentaire visible seulement en full player -->
            <LinearLayout
                android:id="@+id/full_content"
                android:layout_width="350dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <SeekBar
                    android:id="@+id/player_seekbar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="1000"
                    android:progressTint="@color/accentColor"
                    android:thumbTint="@color/accentColor" />

                <RelativeLayout
                    android:layout_width="320dp"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/player_current_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:fontFamily="@font/ibm_plex_sans_regular"
                        android:text="00:00"
                        android:textColor="@color/colorText"/>

                    <TextView
                        android:id="@+id/player_duration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/ibm_plex_sans_regular"
                        android:text="00:00"
                        android:textColor="@color/colorText"/>
                </RelativeLayout>
                <TextView
                    android:id="@+id/position_item"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/ibm_plex_sans_regular"
                    android:text="99/99"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">
                    <ImageButton
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/round_comment_24"
                        android:background="@null"
                        android:scaleType="fitCenter"
                        app:tint="@color/colorText"/>

                    <ImageButton
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_marginHorizontal="12dp"
                        android:src="@drawable/round_favorite_border_24"
                        android:background="@null"
                        android:scaleType="fitCenter"
                        app:tint="@color/colorText"/>

                    <ImageButton
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/round_add_circle_outline_24"
                        android:background="@null"
                        android:scaleType="fitCenter"
                        app:tint="@color/colorText"/>
                    <ImageButton
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_marginHorizontal="12dp"
                        android:src="@drawable/round_playlist_play_24"
                        android:background="@null"
                        android:scaleType="fitCenter"
                        app:tint="@color/colorText"/>
                    <ImageButton
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/round_more_horiz_24"
                        android:background="@null"
                        android:scaleType="fitCenter"
                        app:tint="@color/colorText"/>
                </LinearLayout>
            </LinearLayout>

        </androidx.constraintlayout.motion.widget.MotionLayout>

        <!-- Bottom Navigation collée en bas -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            style="@style/CustomBottomNavigation"
            android:id="@+id/bottom_nav_menu"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:layout_gravity="bottom"
            app:menu="@menu/main_menu"
            app:itemIconTint="@color/nav_item_color"
            app:itemTextColor="@color/nav_item_color"
            android:visibility="visible"/>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</androidx.constraintlayout.widget.ConstraintLayout>