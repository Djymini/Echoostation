<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/music_album"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:layout_marginVertical="24dp"
        android:fontFamily="@font/ibm_plex_sans_medium"
        android:text="@string/album"
        android:textSize="16sp"
        android:textColor="@color/colorText"
        android:textAlignment="center"/>

    <androidx.cardview.widget.CardView
        android:layout_width="350dp"
        android:layout_height="350dp"
        app:cardCornerRadius="12dp">
        <ImageView
            android:id="@+id/cover_art"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/album_cover"
            android:scaleType="centerCrop"
            android:src="@drawable/echoostation_placeholder_album_3x"/>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/music_title"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/ibm_plex_sans_bold"
        android:text="@string/title"
        android:textSize="20sp"
        android:textColor="@color/colorText"
        android:textAlignment="center"
        android:singleLine="true"
        android:ellipsize="end"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="2dp"/>

    <TextView
        android:id="@+id/music_artist"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:fontFamily="@font/ibm_plex_sans_regular"
        android:text="@string/artist"
        android:textSize="14sp"
        android:textColor="@color/colorText"
        android:textAlignment="center"
        android:singleLine="true"
        android:ellipsize="end"/>

    <!-- Boutons -->
    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/repeat_button"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginEnd="24dp"
            android:contentDescription="@string/ic_repeat"
            android:src="@drawable/round_repeat_24"
            app:tint="@color/colorText"/>

        <ImageView
            android:id="@+id/prev_button"
            android:layout_width="47dp"
            android:layout_height="47dp"
            android:contentDescription="@string/ic_previous"
            android:src="@drawable/round_skip_previous_24"
            app:tint="@color/colorText"/>

        <androidx.cardview.widget.CardView
            android:layout_width="64dp"
            android:layout_height="64dp"
            app:cardCornerRadius="64dp"
            android:layout_marginHorizontal="24dp"
            android:backgroundTint="@color/accentColor">
            <ImageView
                android:id="@+id/play_pause_button"
                android:layout_width="47dp"
                android:layout_height="47dp"
                android:layout_gravity="center"
                android:contentDescription="@string/ic_play_pause"
                android:src="@drawable/round_play_arrow_24"
                app:tint="@color/colorText" />
        </androidx.cardview.widget.CardView>

        <ImageView
            android:id="@+id/next_button"
            android:layout_width="47dp"
            android:layout_height="47dp"
            android:contentDescription="@string/ic_next"
            android:src="@drawable/round_skip_next_24"
            app:tint="@color/colorText" />

        <ImageView
            android:id="@+id/shuffle_button"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="24dp"
            android:contentDescription="@string/ic_shuffle"
            android:src="@drawable/round_shuffle_24"
            app:tint="@color/colorText"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="24dp">
        <SeekBar
            android:id="@+id/music_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="1000"
            android:progressTint="@color/accentColor"
            android:thumbTint="@color/accentColor"/>
        <RelativeLayout
            android:layout_width="320dp"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/current_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:fontFamily="@font/ibm_plex_sans_regular"
                android:text="00:00"/>
            <TextView
                android:id="@+id/music_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:fontFamily="@font/ibm_plex_sans_regular"
                android:text="00:00"/>
        </RelativeLayout>
    </LinearLayout>
</LinearLayout>
