<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.MusicFragment">
   <RelativeLayout
       android:id="@+id/button_container"
       android:layout_width="match_parent"
       android:layout_height="wrap_content"
       android:gravity="center_vertical"
       android:paddingHorizontal="8dp"
       android:background="@color/colorSecondary">

      <Spinner
          android:id="@+id/spinner"
          android:layout_width="220dp"
          android:layout_height="wrap_content"
          android:gravity="center_vertical"
          android:layout_alignParentStart="true"
          android:entries="@array/sort_categories"/>

      <ImageButton
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_centerVertical="true"
          android:layout_toStartOf="@id/number_music"
          android:layout_marginEnd="8dp"
          app:tint="@color/colorText"
          android:src="@drawable/ic_shuffle_mini"
          android:background="@color/trueTransparenceColor"
          android:contentDescription="@string/ic_shuffle"/>
      <TextView
          android:id="@+id/number_music"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_centerVertical="true"
          android:layout_alignParentEnd="true"
          android:textColor="@color/colorText"
          android:fontFamily="@font/ibm_plex_sans_medium"
          android:text="@string/counter_music"/>
   </RelativeLayout>

   <androidx.recyclerview.widget.RecyclerView
       android:id="@+id/recycler_view_song"
       android:layout_width="match_parent"
       android:layout_height="match_parent"
       android:layout_below="@id/button_container"
       android:clipToPadding="false"
       android:paddingBottom="82dp"/>


</RelativeLayout>