<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".PlaylistListMusicFragment">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/background_image"
                android:layout_width="match_parent"
                android:layout_height="410dp"
                android:alpha="0.4"
                android:src="@drawable/echoostation_placeholder_album_3x"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="410dp"
                android:background="@drawable/background_album"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/playlist_image_container"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="40dp"
                app:cardCornerRadius="12dp"
                android:backgroundTint="@color/trueTransparenceColor">
                <ImageView
                    android:id="@+id/icon_playlist"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:layout_gravity="center"
                    android:src="@drawable/round_history_24"/>

                <ImageView
                    android:id="@+id/playlist_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/echoostation_placeholder_album_3x"
                    android:visibility="gone"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/playlist_name"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="8dp"
                android:layout_below="@id/playlist_image_container"
                android:fontFamily="@font/ibm_plex_sans_bold"
                android:text="Playlist"
                android:textAlignment="center"
                android:textSize="20dp"/>

            <LinearLayout
                android:id="@+id/info_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/playlist_name"
                android:layout_centerHorizontal="true"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/number_tracks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="99 morceaux"
                    android:textSize="16dp"/>

                <TextView
                    android:id="@+id/duration_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Durée : 99:99"
                    android:textSize="16dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/button_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/info_container"
                android:layout_marginTop="20dp"
                android:layout_centerHorizontal="true"
                android:gravity="center">
                <Button
                    android:id="@+id/play_button"
                    android:layout_width="150dp"
                    android:layout_height="60dp"
                    android:layout_marginEnd="10dp"
                    android:backgroundTint="@color/accentColor"
                    android:text="Jouer"
                    android:textSize="16dp"
                    android:textColor="@color/colorText"
                    android:drawableLeft="@drawable/round_play_arrow_24"
                    android:drawableTint="@color/colorText"/>

                <Button
                    android:id="@+id/shuffle_button"
                    android:layout_width="150dp"
                    android:layout_height="60dp"
                    android:layout_marginStart="10dp"
                    android:backgroundTint="@color/disableText"
                    android:text="Aléatoire"
                    android:textSize="16dp"
                    android:textColor="@color/colorText"
                    android:drawableLeft="@drawable/round_shuffle_24"
                    android:drawableTint="@color/colorText"/>
            </LinearLayout>
        </RelativeLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view_song_playlist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:paddingBottom="82dp"
            android:nestedScrollingEnabled="false"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>