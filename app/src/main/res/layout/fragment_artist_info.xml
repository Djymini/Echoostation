<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".fragments.mediaDetailFragment.ArtistDetailFragment">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingBottom="82dp">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/background_image"
                android:layout_width="match_parent"
                android:layout_height="410dp"
                android:src="@drawable/echoostation_placeholder_album_3x"/>

            <View
                android:id="@+id/view"
                android:layout_width="match_parent"
                android:layout_height="410dp"
                android:background="@drawable/background_album"/>

            <TextView
                android:id="@+id/artist_name"
                android:layout_width="380dp"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_above="@id/info_container"
                android:fontFamily="@font/ibm_plex_sans_bold"
                android:includeFontPadding="false"
                android:text="Artiste"
                android:textAlignment="center"
                android:textSize="35dp"/>

            <LinearLayout
                android:id="@+id/info_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignBottom="@id/view"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="12dp"
                android:gravity="center">
                <TextView
                    android:id="@+id/artist_number_album"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:fontFamily="@font/ibm_plex_sans_medium"
                    android:includeFontPadding="false"
                    android:text="99 Albums"
                    android:textAlignment="center"
                    android:textSize="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:fontFamily="@font/ibm_plex_sans_medium"
                    android:includeFontPadding="false"
                    android:text="  •  "
                    android:textAlignment="center"
                    android:textSize="16dp"/>

                <TextView
                    android:id="@+id/number_tracks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:fontFamily="@font/ibm_plex_sans_medium"
                    android:includeFontPadding="false"
                    android:text="999 titres"
                    android:textAlignment="center"
                    android:textSize="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:fontFamily="@font/ibm_plex_sans_medium"
                    android:includeFontPadding="false"
                    android:text="  •  "
                    android:textAlignment="center"
                    android:textSize="16dp"/>

                <TextView
                    android:id="@+id/duration_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:fontFamily="@font/ibm_plex_sans_medium"
                    android:includeFontPadding="false"
                    android:text="99:99:99"
                    android:textAlignment="center"
                    android:textSize="16dp"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/button_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/info_container"
                android:layout_marginTop="20dp"
                android:layout_centerHorizontal="true"
                android:gravity="center"
                android:visibility="visible">
                <Button
                    android:id="@+id/play_button"
                    android:layout_width="150dp"
                    android:layout_height="60dp"
                    android:layout_marginEnd="10dp"
                    android:backgroundTint="@color/accentColor"
                    android:text="Jouer"
                    android:textSize="16dp"
                    android:textColor="@color/colorText"
                    android:drawableLeft="@drawable/round_play_arrow_24"
                    android:drawableTint="@color/colorText"/>

                <Button
                    android:id="@+id/shuffle_button"
                    android:layout_width="150dp"
                    android:layout_height="60dp"
                    android:layout_marginStart="10dp"
                    android:backgroundTint="@color/disableText"
                    android:text="Aléatoire"
                    android:textSize="16dp"
                    android:textColor="@color/colorText"
                    android:drawableLeft="@drawable/round_shuffle_24"
                    android:drawableTint="@color/colorText"/>
            </LinearLayout>
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/best_song_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:paddingHorizontal="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/title_recycler_view_song"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/ibm_plex_sans_bold"
                    android:includeFontPadding="false"
                    android:text="Titres les plus écoutés"
                    android:textSize="22sp"/>

                <TextView
                    android:id="@+id/button_display_song"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/ibm_plex_sans_medium"
                    android:includeFontPadding="false"
                    android:text="Voir tout"
                    android:textColor="@color/accentColor"
                    android:textSize="18sp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view_best_song"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view_main"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:paddingBottom="82dp"
                android:nestedScrollingEnabled="false"
                android:visibility="visible"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/album_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:paddingHorizontal="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/ibm_plex_sans_bold"
                android:includeFontPadding="false"
                android:text="Albums"
                android:textSize="22sp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view_album"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/album_apparition_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:paddingHorizontal="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/ibm_plex_sans_bold"
                android:includeFontPadding="false"
                android:text="Apparait sur"
                android:textSize="22sp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view_album_apparition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/biographie_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:paddingHorizontal="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/ibm_plex_sans_bold"
                android:includeFontPadding="false"
                android:text="Biographie"
                android:textSize="22sp"/>

            <TextView
                android:id="@+id/artist_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/ibm_plex_sans_medium"
                android:includeFontPadding="false"
                android:text="Text"
                android:textAlignment="gravity"
                android:textSize="14sp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>